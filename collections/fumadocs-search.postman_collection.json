  "item": [
    {
      "id": "512b89f0-03a1-448c-a04b-668b413551f8",
      "name": "Search",
      "description": {
        "content": "Search endpoints for querying documentation content. Results include pages, headings, and text segments ranked by relevance.",
        "type": "text/plain"
      },
      "item": [
        {
          "id": "96cf5dab-c2c0-4246-86e6-06a70bbbba25",
          "name": "Fumadocs Search documentation content",
          "request": {
            "name": "Fumadocs Search documentation content",
            "description": {
              "content": "Searches indexed documentation content and returns a ranked list of matching pages, headings, and text segments. Accepts a query string and optional filters for locale and tag. Returns an empty array when no query is provided. Each result includes the page URL, content type, breadcrumbs, and highlighted content. The default endpoint path is /api/search but can be customized per site.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "api",
                "search"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "query",
                  "value": "<string>",
                  "description": "The search query string. When absent or empty, an empty results array is returned immediately without querying the index."
                },
                {
                  "disabled": false,
                  "key": "locale",
                  "value": "<string>",
                  "description": "BCP 47 locale code to filter results to a specific language version of the documentation site. Useful for internationalized sites."
                },
                {
                  "disabled": false,
                  "key": "tag",
                  "value": "<string>",
                  "description": "One or more comma-separated tag values to restrict search results to specific sections or categories within the documentation. Multiple tags are separated by commas."
                },
                {
                  "disabled": false,
                  "key": "limit",
                  "value": "<integer>",
                  "description": "Maximum number of results to return. When omitted, the search engine's default limit is used."
                }
              ],
              "variable": [
                {
                  "description": "Base URL of the documentation site. Fumadocs is a self-hosted framework; each site sets its own base URL.",
                  "type": "any",
                  "value": "{{baseUrl}}",
                  "key": "baseUrl"
                }
              ]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
          "response": [
            {
              "id": "7c7fe0ab-90ee-4ebf-83cc-4348915d6e82",
